# ============================================================================
# LOKI HORO — environment configuration
# Copy this file to `.env` and fill in real values before deploying.
#   cp .env.example .env
# NEVER commit the real .env (it holds secrets). It is git-ignored.
# ============================================================================

# --- Core -------------------------------------------------------------------
NODE_ENV=production
PORT=5000

# Where the SQLite database + sessions live INSIDE the container. This path is
# on the mounted volume (see docker-compose.yml), so data persists across
# restarts. Leave as-is unless you change the compose volume mount.
DB_PATH=/data/data.db

# The externally-reachable base URL of your site. Used to build the Google
# OAuth callback URL: ${PUBLIC_URL}/api/auth/google/callback
PUBLIC_URL=https://destiny.lokeshmani.com

# --- Secrets (REQUIRED for a real deployment) -------------------------------
# Signs session cookies. Generate a long random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# Bootstrap password for the admin account (amlokesheit@gmail.com), seeded on
# first boot. Change it in-app after your first login, then you can rotate this.
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_admin_password

# --- Google OAuth (optional) ------------------------------------------------
# Leave BOTH blank to disable Google sign-in (email + password still works).
# To enable: create an OAuth 2.0 Client ID in Google Cloud Console with the
# authorized redirect URI: https://destiny.lokeshmani.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
